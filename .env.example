# Gemini — gere sua chave em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui
GENAI_MODEL=gemini-2.5-flash
# ISSTUDIO_TOKEN ainda é aceito como alias legado de GEMINI_API_KEY

# Claude — gere sua chave em: https://console.anthropic.com/settings/keys
CLAUDE_API_KEY=sua_chave_claude_aqui
CLAUDE_MODEL=claude-haiku-4-5

# Escolhe o provedor de IA usado por main.py: "gemini" ou "claude"
LLM_PROVIDER=gemini
